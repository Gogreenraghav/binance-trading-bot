# Binance API Configuration
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=false

# News API Configuration
NEWS_API_KEY=your_news_api_key_here
NEWS_SOURCES=reuters,bloomberg,coindesk,cryptopanic

# Trading Configuration
TRADING_PAIR=BTCUSDT
RISK_PERCENTAGE=2
DAILY_LOSS_LIMIT=5
MAX_OPEN_POSITIONS=3

# Strategy Configuration
ACTIVE_STRATEGIES=trend,meanReversion,breakout,newsBased
STRATEGY_WEIGHTS=0.4,0.3,0.2,0.1

# Risk Management
STOP_LOSS_PERCENTAGE=2
TAKE_PROFIT_PERCENTAGE=4
MAX_POSITION_SIZE=1000

# Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_UPDATE_INTERVAL=1000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/trading-bot.log

# Database Configuration (Optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=postgres
DB_PASSWORD=postgres

# Email Alerts (Optional)
EMAIL_ALERTS=false
EMAIL_FROM=bot@example.com
EMAIL_TO=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Performance Monitoring
METRICS_INTERVAL=300000
HEALTH_CHECK_INTERVAL=60000

# Advanced Settings
TRADING_HOURS_START=00:00
TRADING_HOURS_END=23:59
MARKET_VOLATILITY_THRESHOLD=0.5
MIN_TRADE_AMOUNT=10
MAX_LEVERAGE=1